# RealSense React Viewer Environment Variables

# ============================================
# AI Chat Assistant - Choose ONE provider:
# ============================================

# Option 1: Groq (RECOMMENDED - FREE)
# Get your free key at: https://console.groq.com/keys
# Uses Llama 3.3 70B - fast and capable
VITE_GROQ_API_KEY=

# Option 2: OpenAI (Paid)
# Get your key at: https://platform.openai.com/api-keys
# Uses GPT-4o-mini
# VITE_OPENAI_API_KEY=

# Option 3: Custom OpenAI-compatible API
# VITE_LLM_API_URL=http://localhost:11434/v1/chat/completions
# VITE_LLM_API_KEY=
# VITE_LLM_MODEL=llama3

# ============================================
# Backend API URL (optional)
# ============================================
# VITE_API_URL=http://localhost:8000
